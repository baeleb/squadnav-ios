{
  "$schema": "https://opencode.ai/config.json",
  // Apple mcpbridge's XcodeMV tool ships an invalid schema (string enum on
  // an object-typed property); Moonshot/Kimi rejects the entire request
  // because of it. Disable that one tool; everything else is valid.
  "tools": {
    "xcode_XcodeMV": false
  },
  "mcp": {
    // Community Xcode automation: build/test schemes, simulator
    // boot/install/launch, UI interaction. https://github.com/cameroncooke/XcodeBuildMCP
    "xcodebuild": {
      "type": "local",
      // NOTE: v2.x CLI requires the `mcp` subcommand — bare invocation
      // prints usage and exits, and the MCP client reports "server unavailable".
      "command": ["npx", "-y", "xcodebuildmcp@2.6.2", "mcp"],
      "enabled": true
    },
    // Apple's official MCP bridge bundled with Xcode 26+:
    // editor-aware build, docs, project structure.
    "xcode": {
      "type": "local",
      "command": ["xcrun", "mcpbridge"],
      "enabled": true
    }
  }
}
