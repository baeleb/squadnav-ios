<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TEMPLATE ONLY — the real GoogleService-Info.plist is gitignored.
  Download yours from Firebase console → squadnav-dev → Project settings
  → Your apps → SquadNav iOS (dev), and place it at this exact path:
      SquadNav/Resources/GoogleService-Info.plist
  Then copy its REVERSED_CLIENT_ID value into project.yml
  (CFBundleURLSchemes) and run: xcodegen generate
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>dummy.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.dummy</string>
	<key>API_KEY</key>
	<string>AIzaSy1234567890abcdefghijklmnopqrstuvw</string>
	<key>GCM_SENDER_ID</key>
	<string>123456789</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.squadnav.SquadNav</string>
	<key>PROJECT_ID</key>
	<string>squadnav-dummy</string>
	<key>STORAGE_BUCKET</key>
	<string>squadnav-dummy.appspot.com</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:123456789:ios:abcdef123456</string>
</dict>
</plist>
